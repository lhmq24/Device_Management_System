{
  "compilerOptions": {
    "target": "es6",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": ["src/**/*.vue", "src/**/*.js", "src/**/*.ts"],
  "exclude": ["node_modules"],
  "vueCompilerOptions": {
    "target": 3
  }
}
