  "openapi": "3.1.1",
  "info": {
    "title": "Device Maintenance API",
    "version": "1.0.0",
    "description": "A simple device maintenance app API"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "paths": {
    "/":{
        "get": {
            "summary": "Get API status",
            "description": "Returns the status of the API",
            "responses": {
            "200": {
                "description": "API is running",
                "content": {
                "application/json": {
                    "schema": {
                    "type": "object",
                    "properties": {
                        "status": {
                            "type": "string",
                            "example": "success"
                        },
                        "data": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "API is running"
                                }
                            }
                        }
                    }
                    }
                }
                }
            },
            "500": {
                "description": "Internal server error"
            }
            }
        }
    }
    
  },
